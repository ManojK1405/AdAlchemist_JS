// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id
  email     String
  name      String
  image     String
  credits   Int      @default(20)
  metaAccessToken String?
  metaPageId      String?
  hasProAccess    Boolean  @default(false)
  hasPipelineAccess Boolean @default(false)
  hasBrandHubAccess Boolean @default(false)
  lastSpinAt      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects     Project[]
  comments     Comment[]
  commentLikes CommentLike[]
  projectLikes ProjectLike[]
  discussions  Discussion[]
  brandKits    BrandKit[]
  sentTips     Tip[]         @relation("SentTips")
  receivedTips Tip[]         @relation("ReceivedTips")
  transactions Transaction[]
  generationJobs GenerationJob[]
  couponUsages   CouponUsage[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  planId          String
  amount          Float
  credits         Int
  paymentId       String?  // Razorpay Payment ID
  orderId         String   @unique // Razorpay Order ID
  signature       String?  // Razorpay Signature
  status          String   @default("pending") // pending, success, failed
  couponId        String?  // ID of the coupon used
  discountApplied Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tip {
  id          String   @id @default(uuid())
  amount      Float
  senderId    String
  recipientId String
  createdAt   DateTime @default(now())

  sender      User     @relation("SentTips", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("ReceivedTips", fields: [recipientId], references: [id], onDelete: Cascade)
}

model Project {
  id                 String   @id @default(uuid())
  name               String
  userId             String
  productName        String   
  productDescription String   @default("")
  userPrompt         String   @default("")
  aspectRatio        String   @default("9:16")
  targetLength       Int      @default(5)
  uploadedImages     String[]
  generatedImage     String   @default("")
  generatedVideo     String   @default("")
  imageVersions      String[] @default([])
  videoVersions      String[] @default([])
  isGenerating       Boolean  @default(false)
  isPublished        Boolean  @default(false)
  brandLogo          String   @default("")
  error              String   @default("")
  
  // Ad Evaluation
  engagementScore    Int      @default(0)
  scoringFeedback    String   @default("")
  videoEngagementScore Int    @default(0)
  videoScoringFeedback String   @default("")
  isReviewEnabled    Boolean  @default(false)
  imageScores        Json     @default("[]")
  videoScores        Json     @default("[]")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments     Comment[]
  projectLikes ProjectLike[]
  generationJobs GenerationJob[]
  brandKitId   String?
  brandKit     BrandKit?     @relation(fields: [brandKitId], references: [id])
}

model GenerationJob {
  id        String   @id @default(uuid())
  userId    String
  projectId String?
  type      String   // IMAGE, VIDEO, EDIT_IMAGE, EDIT_VIDEO
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  payload   Json     // Input data for generation
  position  Int      @default(0)
  error     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Comment {
  id           String   @id @default(uuid())
  content      String
  userId       String?
  projectId    String?
  discussionId String?
  parentId     String?
  isClientReview Boolean @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent       Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]   @relation("CommentReplies")
  likes        CommentLike[]
}


model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Discussion {
  id        String   @id @default(uuid())
  title     String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandKit {
  id             String  @id @default(uuid())
  name           String  @default("My Brand")
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault      Boolean @default(false)
  
  projects       Project[]
  logoDark       String? @default("")
  logoLight      String? @default("")
  primaryColor   String? @default("#06b6d4")
  secondaryColor String? @default("#4f46e5")
  fontPrimary    String? @default("Inter")
  fontSecondary  String? @default("Montserrat")
  
  // Brand Identity
  brandVoice     String? @default("Professional") // Sassy, Luxury, Playful, etc.
  targetAudience String? @default("General")
  description    String? @default("")
  
  updatedAt      DateTime @updatedAt
}

model GlobalSettings {
  id                String  @id @default("system")
  enableImageGen    Boolean @default(true)
  enableVideoGen    Boolean @default(true)
  enableDBO         Boolean @default(true)
  enableProStudio   Boolean @default(true)
  enableBrandHub    Boolean @default(true)
  showMockAssets    Boolean @default(false)
  
  // Growth & Dark Tactics
  enableSocialProof Boolean @default(true)
  enableScarcity    Boolean @default(true)
  enableUrgency     Boolean @default(true)
  enableAnchoring   Boolean @default(true)
  enableShaming     Boolean @default(true)
  
  updatedAt         DateTime @updatedAt
}

model Coupon {
  id        String   @id @default(uuid())
  code      String   @unique
  type      String   // FREE_CREDITS, DISCOUNT
  value     Float    // Credit amount or Discount percentage
  isActive  Boolean  @default(true)
  maxUses   Int?     // Total uses allowed globally (null for unlimited)
  usedCount Int      @default(0)
  expiryDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages    CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(uuid())
  userId    String
  couponId  String
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
}
