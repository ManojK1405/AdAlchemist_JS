PORT=3000

# Cloudinary Setup for asset storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Clerk Authentication Keys (Development / Test)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Clerk Authentication (Production Live Keys)
#CLERK_PUBLISHABLE_KEY=pk_live_...
#CLERK_SECRET_KEY=sk_live_...

# Google AI Studio API Key (For Gemini & Veo)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# Prisma Database connection URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Razorpay keys (Test Environment)
#RAZORPAY_KEY_ID=rzp_test_...
#RAZORPAY_KEY_SECRET=your_test_secret

# Razorpay keys (Live Environment)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_live_secret

# Razorpay Webhook Secret (Same for test and live)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --- Feature Toggles (Costs & Access) ---
ENABLE_IMAGE_GEN=true
ENABLE_VIDEO_GEN=true
ADMIN_PASSCODE=1234